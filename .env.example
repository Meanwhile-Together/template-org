# Per-deploy environment. Copy to .env in the org root after `mtx create org`,
# then fill in the values. NEVER commit the real .env — it is already in .gitignore.
#
# See rule-of-law §1 (Deployable host is always an org host) and MTX_DEPLOY_CONTRACT.md
# for what lanes these tokens drive.

# --- Railway (required for `mtx deploy` / Terraform apply) ---
# Account token: https://railway.app/account/tokens — drives Terraform provider auth.
RAILWAY_ACCOUNT_TOKEN=

# Per-environment project tokens: used for `railway up` deploys (apply.sh picks the
# right one based on ENVIRONMENT=staging|production).
RAILWAY_PROJECT_TOKEN_STAGING=
RAILWAY_PROJECT_TOKEN_PRODUCTION=

# Optional: pin a specific Railway workspace / project. If omitted, apply.sh resolves
# the workspace from config/org.json.org.owner and creates / reuses a project by name.
# RAILWAY_WORKSPACE_ID=
# RAILWAY_PROJECT_ID=

# --- Master lane (admin / backend service) ---
# When true, the backend service runs as the master lane (verticals / components /
# cross-tenant admin). See SERVICE_LANE_SEPARATION.md. On the unified app service this
# must be unset / false.
RUN_AS_MASTER=false

# Master-issued JWTs that project backends verify. Generate a long random value for
# real deployments (e.g. `openssl rand -hex 48`). Leave blank to skip master admin auth
# during local dev.
MASTER_JWT_SECRET=
