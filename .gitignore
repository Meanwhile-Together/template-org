dist
node_modules

# Local secrets (Railway / JWT / DB URLs — mtx deploy reads .env)
.env
.env.*
!.env.example
# Runtime config — schema examples live as config/*.example.json.
# mtx_org_scaffold_deploy_config_surface writes config/server.json on `mtx create org` from server.json.example,
# and the shared/server loader auto-copies backend.example.json → backend.json on first boot.
# deploy.json is populated by `mtx deploy` first-run (pins the Railway projectId).
# config/admin-grants.json + config/agent.json are master-lane / agent-lane runtime only — never ship in a stock org template.
config/server.json
config/backend.json
config/deploy.json
config/admin-grants.json
config/agent.json
# Note: config/org.json is TRACKED — it carries the org's canonical identity
# (rule-of-law §1 2026-04-20 Config triad) and `mtx create org` rewrites it from
# the template default. Do not ignore it.
# Generated by MTX lib/vendor-payloads-from-config.sh during prepare:railway (deploy path rewrites).
config/server.json.railway
# Legacy mirrored node_modules (older prepare:railway)
targets/server/runtime/
# Note: targets/server/dist/ and targets/server/npm-packs/ are NOT listed here so
# `railway up` and Git include the prepared bundle (run npm run prepare:railway before deploy).

# Terraform (mtx deploy — local state; do not commit)
.terraform/
.terraform.lock.hcl
terraform/.terraform/
terraform/terraform.tfstate
terraform/terraform.tfstate.*
