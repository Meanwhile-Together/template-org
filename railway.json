{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "bash scripts/railway-build.sh"
  },
  "deploy": {
    "preDeployCommand": "node scripts/railway-migrate.mjs",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
