{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "export PATH=\"/usr/local/bin:/usr/bin:$PATH\" && mtx project railway-build"
  },
  "deploy": {
    "startCommand": "sh -c \"PROJECT_ROOT=/app DISABLE_BROWSER_AUTOMATION=1 exec node targets/server/dist/index.js\"",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
