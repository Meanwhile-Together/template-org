{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "bash scripts/railway-build.sh"
  },
  "deploy": {
    "preDeployCommand": "node scripts/railway-migrate.mjs",
    "startCommand": "NODE_OPTIONS=\"--dns-result-order=ipv6first\" PROJECT_ROOT=/app DISABLE_BROWSER_AUTOMATION=1 node targets/server/dist/index.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
