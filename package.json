{
  "name": "@meanwhile-together/template-org",
  "version": "1.0.0",
  "private": true,
  "description": "Canonical org-host scaffold for `mtx create org`. Ships the config triad (config/org.json + config/server.json + example backend/deploy configs), a payloads/admin seed, and the shared org deploy surface (scripts/, targets/, terraform/, railpack).",
  "dependencies": {
    "@meanwhile-together/demo": "file:targets/server/npm-packs/meanwhile-together-demo-1.0.0.tgz",
    "@meanwhile-together/engine": "file:targets/server/npm-packs/meanwhile-together-engine-1.0.0.tgz",
    "@meanwhile-together/shared": "file:../project-bridge/shared",
    "@meanwhile-together/ui": "file:../project-bridge/ui",
    "@prisma/adapter-better-sqlite3": "^7.0.0",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "pg": "^8.13.1",
    "router": "^2.2.0",
    "http-proxy-middleware": "^2.0.6",
    "playwright": "^1.54.2",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@meanwhile-together/engine": "file:../project-bridge/engine"
  },
  "scripts": {
    "prepare:railway": "bash scripts/prepare-railway-artifact.sh",
    "dev": "bash scripts/org-dev-server.sh",
    "build:server": "bash scripts/org-build-server.sh",
    "build:backend-server": "npm run build:server"
  }
}
